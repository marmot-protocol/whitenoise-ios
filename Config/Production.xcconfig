// Production flavor. Installs as dev.ipf.whitenoise.ios.
#include "Shared.xcconfig"

WN_FLAVOR = production
WN_DISPLAY_NAME = White Noise
WN_URL_SCHEME = whitenoise

PRODUCT_BUNDLE_IDENTIFIER = dev.ipf.whitenoise.ios
NSE_BUNDLE_IDENTIFIER = dev.ipf.whitenoise.ios.NotificationService

// NSE shares the app's App Group and keychain group (keyed to the app bundle id).
APP_GROUP_IDENTIFIER = group.dev.ipf.whitenoise.ios
KEYCHAIN_ACCESS_GROUP = $(AppIdentifierPrefix)dev.ipf.whitenoise.ios

ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
WHITENOISE_TELEMETRY_ENVIRONMENT = production
WHITENOISE_PUSH_SERVER_PUBKEY_HEX = 73a4996bd18de19f6ac5f6ad42f5f2671eba6e5b739ea9695f07b00b0693fc04
