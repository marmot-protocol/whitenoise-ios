    "NSCameraUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise verwendet die Kamera, um Profil-QR-Codes zu scannen und Fotos für verschlüsselte Chats aufzunehmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise uses the camera to scan profile QR codes and take photos for encrypted chats."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise usa la cámara para escanear códigos QR de perfil y tomar fotos para chats cifrados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise utilise l’appareil photo pour scanner des QR codes de profil et prendre des photos pour les conversations chiffrées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise usa la fotocamera per scansionare i codici QR del profilo e scattare foto per le chat crittografate."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O White Noise usa a câmera para escanear QR codes de perfil e tirar fotos para conversas criptografadas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise использует камеру для сканирования QR-кодов профилей и съемки фотографий для зашифрованных чатов."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise, profil QR kodlarını taramak ve şifreli sohbetler için fotoğraf çekmek amacıyla kamerayı kullanır."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise 使用相机扫描个人资料二维码，并为加密聊天拍摄照片。"
