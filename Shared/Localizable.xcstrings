    "You'll stay in the group, but another admin will need to restore your admin status." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie bleiben in der Gruppe, aber ein anderer Administrator muss Ihren Administratorstatus wiederherstellen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permanecerás en el grupo, pero otro administrador deberá restaurar tu estado de administrador."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous resterez dans le groupe, mais un autre administrateur devra restaurer votre statut d'administrateur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rimarrai nel gruppo, ma un altro amministratore dovrà ripristinare il tuo stato di amministratore."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você permanecerá no grupo, mas outro administrador precisará restaurar seu status de administrador."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы останетесь в группе, но другой администратор должен будет восстановить ваш статус администратора."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grupta kalacaksınız ancak başka bir yöneticinin yönetici durumunuzu geri yüklemesi gerekecek."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您将留在群组中，但另一位管理员需要恢复您的管理员状态。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您將留在群組中，但另一位管理員需要恢復您的管理員狀態。"
          }
        }
      }
    },
    "You'll step down as admin first, then stop receiving messages from this group." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie treten zunächst als Administrator zurück und erhalten dann keine Nachrichten mehr von dieser Gruppe."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primero dejarás de ser administrador y luego dejarás de recibir mensajes de este grupo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous quitterez d’abord votre poste d’administrateur, puis cesserez de recevoir des messages de ce groupe."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prima dimetterai la carica di amministratore, poi smetterai di ricevere messaggi da questo gruppo."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você primeiro deixará o cargo de administrador e depois deixará de receber mensagens deste grupo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сначала вы уйдете с поста администратора, а затем перестанете получать сообщения от этой группы."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Önce yöneticilikten ayrılacaksınız, ardından bu gruptan mesaj almayı bırakacaksınız."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您将首先辞去管理员身份，然后停止接收来自该群组的消息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您將首先辭去管理員身份，然後停止接收來自該群組的訊息。"
          }
        }
      }
    },
    "You'll stop receiving messages from this group. Other members will see a system message." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie erhalten keine Nachrichten mehr von dieser Gruppe. Andere Mitglieder sehen eine Systemmeldung."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dejarás de recibir mensajes de este grupo. Otros miembros verán un mensaje del sistema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous ne recevrez plus de messages de ce groupe. Les autres membres verront un message système."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non riceverai più messaggi da questo gruppo. Gli altri membri vedranno un messaggio di sistema."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você deixará de receber mensagens deste grupo. Outros membros verão uma mensagem do sistema."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы перестанете получать сообщения от этой группы. Остальные участники увидят системное сообщение."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu gruptan mesaj almayı bırakacaksınız. Diğer üyeler bir sistem mesajı göreceklerdir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您将停止接收来自该群组的消息。其他成员将看到一条系统消息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您將停止接收來自該群組的訊息。其他成員將看到一條系統訊息。"
          }
        }
      }
    },
    "You're the only admin. Make another member an admin before you leave." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie sind der einzige Administrator. Machen Sie ein anderes Mitglied zum Administrator, bevor Sie gehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eres el único administrador. Convierte a otro miembro en administrador antes de irte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes le seul administrateur. Faites d’un autre membre un administrateur avant de partir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei l'unico amministratore. Rendi un altro membro un amministratore prima di andartene."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você é o único administrador. Torne outro membro um administrador antes de sair."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты единственный администратор. Прежде чем уйти, сделайте другого участника администратором."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tek yönetici sensin. Ayrılmadan önce başka bir üyeyi yönetici yapın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您是唯一的管理员。在您离开之前让另一位成员成为管理员。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您是唯一的管理員。在您離開之前讓另一位成員成為管理員。"
          }
        }
      }
    },
