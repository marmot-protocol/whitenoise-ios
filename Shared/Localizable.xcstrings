    "Native push is unavailable in this build until a White Noise push server public key is configured." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nativer Push ist in diesem Build erst verfügbar, wenn ein öffentlicher Schlüssel des White Noise-Push-Servers konfiguriert ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La inserción nativa no está disponible en esta compilación hasta que se configure una llave pública del servidor de inserción WhiteNoise."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le push natif n'est pas disponible dans cette version jusqu'à ce qu'une clé publique du serveur push White Noise soit configurée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il push nativo non è disponibile in questa build finché non viene configurata una chiave pubblica del server push White Noise."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O push nativo não estará disponível nesta compilação até que uma chave pública do servidor push White Noise seja configurada."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Собственная рассылка недоступна в этой сборке до тех пор, пока не будет настроен открытый ключ push-сервера White Noise."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir White Noise push sunucusu ortak anahtarı yapılandırılana kadar bu yapıda yerel push kullanılamaz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在配置 White Noise 推送服务器公钥之前，本机推送在此版本中不可用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在配置 White Noise 推播伺服器公鑰之前，本機推送在此版本中不可用。"
          }
        }
      }
    },
    "Native push registers only an encrypted APNS token with White Noise. Apple receives generic notification wakes." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Native Push registriert nur ein verschlüsseltes APNS-Token mit White Noise. Apple erhält generische Benachrichtigungen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La inserción nativa registra solo un token APNS cifrado con White Noise. Apple recibe alertas de notificación genéricas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le push natif enregistre uniquement un jeton APNS crypté avec White Noise. Apple reçoit des réveils de notification génériques."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il push nativo registra solo un token APNS crittografato con White Noise. Apple riceve attivazioni di notifiche generiche."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O push nativo registra apenas um token APNS criptografado com White Noise. A Apple recebe notificações genéricas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Встроенная push-регистрация регистрирует только зашифрованный токен APNS с помощью White Noise. Apple получает стандартные уведомления о пробуждении."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yerel push, yalnızca White Noise ile şifrelenmiş bir APNS jetonunu kaydeder. Apple genel bildirim uyandırmalarını alır."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本机推送仅向 White Noise 注册加密的 APNS 令牌。 Apple 收到通用通知唤醒。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本機推送僅向 White Noise 註冊加密的 APNS 令牌。 Apple 收到通用通知喚醒。"
          }
        }
      }
    },
