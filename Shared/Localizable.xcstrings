    "Deletes every local audit JSONL file on this device. Live recorders rotate to fresh files when audit logging is still on." : {
      "comment" : "A description of the action of deleting all audit logs.",
      "extractionState" : "manual",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Löscht jede lokale Audit-JSONL-Datei auf diesem Gerät. Live-Rekorder wechseln zu neuen Dateien, wenn die Audit-Protokollierung noch aktiv ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deletes every local audit JSONL file on this device. Live recorders rotate to fresh files when audit logging is still on."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina cada archivo JSONL de auditoría local en este dispositivo. Los grabadores activos rotan a archivos nuevos cuando el registro de auditoría sigue activo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime chaque fichier JSONL d'audit local sur cet appareil. Les enregistreurs actifs basculent vers de nouveaux fichiers lorsque la journalisation d'audit est toujours activée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina ogni file JSONL di audit locale su questo dispositivo. I registratori attivi ruotano su nuovi file quando la registrazione di audit è ancora attiva."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exclui cada arquivo JSONL de auditoria local neste dispositivo. Gravadores ativos alternam para arquivos novos quando o registro de auditoria ainda está ativo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удаляет каждый локальный JSONL-файл аудита на этом устройстве. Активные рекордеры переключаются на новые файлы, если аудит всё ещё включён."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu cihazdaki her yerel denetim JSONL dosyasını siler. Denetim günlüğü açıkken canlı kaydediciler yeni dosyalara geçer."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "删除此设备上的每个本地审计 JSONL 文件。审计日志仍开启时，正在运行的记录器会轮换到新文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "刪除此裝置上的每個本地稽核 JSONL 檔案。稽核日誌仍開啟時，正在執行的記錄器會輪換到新檔案。"
          }
        }
      }
    },
