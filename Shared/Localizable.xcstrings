    "Your passphrase encrypts the exported ncryptsec1 backup. Marmot never stores it." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Passphrase verschlüsselt die exportierte ncryptsec1-Sicherung. Marmot speichert sie nie."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu frase de contraseña cifra la copia ncryptsec1 exportada. Marmot nunca la almacena."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre phrase secrète chiffre la sauvegarde ncryptsec1 exportée. Marmot ne la stocke jamais."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tua passphrase crittografa il backup ncryptsec1 esportato. Marmot non la memorizza mai."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua frase secreta criptografa o backup ncryptsec1 exportado. O Marmot nunca a armazena."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваша парольная фраза шифрует экспортированную резервную копию ncryptsec1. Marmot никогда ее не сохраняет."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parolanız dışa aktarılan ncryptsec1 yedeğini şifreler. Marmot bunu asla saklamaz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的密码短语会加密导出的 ncryptsec1 备份。Marmot 永远不会存储它。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的密碼短語會加密匯出的 ncryptsec1 備份。Marmot 永遠不會儲存它。"
          }
        }
      }
    }
  },
  "version" : "1.1"
