    "Swipe a chat to archive it; archived chats stay active and still notify you." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wischen Sie über einen Chat, um ihn zu archivieren. Archivierte Chats bleiben aktiv und benachrichtigen Sie weiterhin."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desliza un chat para archivarlo; los chats archivados permanecen activos y aún así le notifican."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites glisser une discussion pour l'archiver ; les discussions archivées restent actives et vous informent toujours."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scorri una chat per archiviarla; le chat archiviate rimangono attive e ti avvisano comunque."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deslize um bate-papo para arquivá-lo; os bate-papos arquivados permanecem ativos e ainda notificam você."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проведите чат, чтобы заархивировать его; заархивированные чаты остаются активными и по-прежнему уведомляют вас."
