    "APNS did not return a new device token in time. Try again, or check notification permission in Settings." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS hat nicht rechtzeitig ein neues Geräte-Token zurückgegeben. Versuche es erneut oder prüfe die Benachrichtigungsberechtigung in den Einstellungen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS no devolvió un token de dispositivo nuevo a tiempo. Inténtalo de nuevo o revisa el permiso de notificaciones en Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS n’a pas renvoyé un nouveau jeton d’appareil à temps. Réessayez ou vérifiez l’autorisation de notifications dans Réglages."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS non ha restituito un nuovo token del dispositivo in tempo. Riprova o controlla l’autorizzazione alle notifiche in Impostazioni."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS não devolveu um token de dispositivo novo a tempo. Tente novamente ou verifique a permissão de notificações em Ajustes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS не вернул новый токен устройства вовремя. Повторите попытку или проверьте разрешение на уведомления в Настройках."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS zamanında yeni bir cihaz belirteci döndürmedi. Tekrar deneyin veya Ayarlar’daki bildirim iznini kontrol edin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS 未及时返回新的设备令牌。请重试，或在设置中检查通知权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APNS 未及時返回新的裝置令牌。請再試一次，或在設定中檢查通知權限。"
          }
        }
      }
    },
