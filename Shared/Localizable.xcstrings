    "Choose whether White Noise follows your device appearance or always uses a light or dark theme." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle, ob White Noise dem Erscheinungsbild deines Geräts folgt oder immer ein helles oder dunkles Design verwendet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si White Noise sigue la apariencia de tu dispositivo o usa siempre un tema claro u oscuro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez si White Noise suit l’apparence de votre appareil ou utilise toujours un thème clair ou sombre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli se White Noise segue l’aspetto del dispositivo o usa sempre un tema chiaro o scuro."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha se o White Noise segue a aparência do dispositivo ou sempre usa um tema claro ou escuro."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выберите, будет ли White Noise следовать оформлению устройства или всегда использовать светлую либо тёмную тему."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "White Noise’ın cihaz görünümünü mü izleyeceğini yoksa her zaman açık ya da koyu tema mı kullanacağını seçin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择 White Noise 是跟随设备外观，还是始终使用浅色或深色主题。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選擇 White Noise 要跟隨裝置外觀，還是永遠使用淺色或深色主題。"
          }
        }
      }
    },
