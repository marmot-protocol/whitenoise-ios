    "Signing out removes this profile and its local key material from this device." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch das Abmelden werden dieses Profil und sein lokales Schlüsselmaterial von diesem Gerät entfernt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cerrar sesión elimina este perfil y su material de llaves local de este dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La déconnexion supprime ce profil et ses clés locales de cet appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uscire rimuove questo profilo e il suo materiale di chiave locale da questo dispositivo."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sair remove este perfil e seu material de chave local deste dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выход удаляет этот профиль и его локальный ключевой материал с этого устройства."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oturumu kapatmak bu profili ve yerel anahtar materyalini bu cihazdan kaldırır."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注销会从此设备移除此个人资料及其本地密钥材料。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "登出會從此裝置移除此個人資料及其本機金鑰材料。"
          }
        }
      }
    },
