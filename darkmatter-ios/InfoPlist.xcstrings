    "NSCameraUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter uses the camera to scan profile QR codes so you can add people to encrypted chats."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter verwendet die Kamera, um den Profil-QR-Code eines Kontakts zu scannen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter usa la cámara para escanear el código QR del perfil de un contacto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter utilise l’appareil photo pour scanner le code QR du profil d’un contact."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter usa la fotocamera per scansionare il codice QR del profilo di un contatto."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Dark Matter usa a câmera para escanear o QR code do perfil de um contato."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter использует камеру для сканирования QR-кода профиля контакта."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter, bir kişinin profil QR kodunu taramak için kamerayı kullanır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter 使用相机扫描联系人的个人资料二维码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark Matter 會使用相機掃描聯絡人的個人檔案 QR 碼。"
          }
        }
      }
    }
  },
  "version": "1.0"
